datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. Tenant Model
model Tenant {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  branches  String[] @default([])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 2. User Model (auth.model.js)
model User {
  id            String    @id @default(uuid())
  staffName     String
  role          String?
  shift         String?
  username      String?
  phoneNo       String?
  email         String?   @unique
  password      String
  tenantId      String?
  admin_id      String?
  branchName    String
  staying       Boolean   @default(true)
  vacatedate    DateTime?
  refreshToken  String?
  otp           String?
  otpExpiry     DateTime?
  isdeleted     Boolean   @default(false)
  deleteddate   DateTime?
  deleteby      String?
  module        String?   @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 3. Room Model (Room&Residence.model.js)
model Room {
  id          String    @id @default(uuid())
  tenantId    String
  branchName  String
  Floor       String
  RoomNo      String
  RoomType    String
  category    String    @default("Resident")
  Capacity    Int
  Occupied    Int       @default(0)
  Status      String    @default("Vacant")
  Rate        Float     @default(0)
  isdeleted   Boolean   @default(false)
  deleteddate DateTime?
  deleteby    String?
  module      String?   @default("room")
  users       String[]  @default([])
  pgUsers     Json?     @default("[]") // stores PG users as JSON array of objects
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([tenantId, branchName, Floor, RoomNo])
}

// 4. Register Model (register.model.js - Resident registration)
model Register {
  id              String    @id @default(uuid())
  tenantId        String
  branchName      String
  DateOfJoining   DateTime  @default(now())
  Registerdate    DateTime  @default(now())
  RoomNo          String?
  BillNo          String
  Name            String
  DateOfBirth     DateTime
  MobileNo        String
  SameAsWhatsapp  Boolean   @default(false)
  Whatsapp        String
  Email           String
  PermanentAddress String
  AddharNumber    String
  FoodType        String
  RoomType        String
  FloorNo         String    @default("-")
  Deposit         Float     @default(0)
  Discount        Float     @default(0)
  Advance         Float     @default(0)
  Parking         Boolean   @default(false)
  vehicleNo       String?
  status          String    @default("staying")
  staying         Boolean   @default(true)
  vacatedate      DateTime?
  Rejoiningdate   DateTime?
  isdeleted       Boolean   @default(false)
  deleteddate     DateTime?
  deleteby        String?
  module          String?   @default("register")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// 5. PGData Model (pgdata.model.js)
model PGData {
  id            String    @id @default(uuid())
  tenantId      String
  branchName    String
  RoomNo        String?
  BillNo        String
  checkin       DateTime  @default(now())
  checkout      DateTime?
  Name          String
  MobileNo      String
  Reason        String
  Rent          Float     @default(0)
  PaymentMethod String
  Paymentstatus String    @default("pending")
  Discount      Float     @default(0)
  status        String    @default("staying")
  staying       Boolean   @default(true)
  AddharNumber  String?
  costPerDay    Float     @default(0)
  dayStayed     Int       @default(1)
  advance       Float     @default(0)
  due           Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 6. Subscription Model (subscription.model.js)
model Subscription {
  id                    String    @id @default(uuid())
  organizationId        String    @unique
  planName              String
  amount                Float
  currency              String
  billingCycle          String
  subscriptionStatus    String
  paymentStatus         String
  hasUsedTrial          Boolean   @default(false)
  trialStartDate        DateTime?
  trialEndDate          DateTime?
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  paymentDate           DateTime?
  razorpayOrderId       String?
  razorpayPaymentId     String?
  razorpaySignature     String?
  cancelledAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// 7. Settings Model (settings.model.js)
model Settings {
  id                      String   @id @default(uuid())
  tenantId                String   @unique
  branchName              String
  businessName            String?
  businessLogo            String?
  businessAddress         String?
  businessGST             String?
  businessPhone           String?
  businessEmail           String?
  upiId                   String?
  rentDueDay              Int      @default(5)
  dueGracePeriod          Int      @default(3)
  automaticDueGeneration  Boolean  @default(true)
  taxEnabled              Boolean  @default(false)
  taxRate                 Float    @default(0)
  maintenanceCharge       Float    @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// 8. Notification Model (notification.model.js)
model Notification {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String?
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 9. VacationForm Model (vacationform.model.js)
model VacationForm {
  id           String    @id @default(uuid())
  tenantId     String
  userId       String
  checkOutDate DateTime
  checkInDate  DateTime
  reason       String?
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// 10. Item Model (StoreRoomExpenses/item.model.js)
model Item {
  id         String   @id @default(uuid())
  tenantId   String
  branchName String
  date       DateTime @default(now())
  name       String
  quantity   Float
  price      Float
  category   String
  brandName  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 11. StoreRoomInventory Model (StoreRoomInventory/item.model.js)
model StoreRoomInventory {
  id                String   @id @default(uuid())
  tenantId          String
  branchName        String
  itemName          String
  category          String
  totalQuantity     Float    @default(0)
  remainingQuantity Float    @default(0)
  price             Float    @default(0)
  unit              String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// 12. Menu Model (foodAndKitchen/menu/menu.model.js)
model Menu {
  id         String   @id @default(uuid())
  tenantId   String
  branchName String
  day        String
  breakfast  String?
  lunch      String?
  snacks     String?
  dinner     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 13. RoomRent Model (FinanceAndUtilities/RoomRent/roomRent.model.js)
model RoomRent {
  id             String    @id @default(uuid())
  tenantId       String
  branchName     String
  userId         String
  Name           String
  RoomNo         String
  Rent           Float
  due            Float     @default(0)
  Discount       Float     @default(0)
  paid           Float     @default(0)
  PaymentMethod  String?
  paymentStatus  String    @default("pending")
  paymentDate    DateTime?
  month          String
  year           Int
  isdeleted      Boolean   @default(false)
  deleteddate    DateTime?
  deleteby       String?
  module         String?   @default("roomrent")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// 14. Payroll Model (FinanceAndUtilities/Payroll/payroll.model.js)
model Payroll {
  id             String    @id @default(uuid())
  tenantId       String
  branchName     String
  employeeId     String
  name           String
  role           String
  salary         Float
  due            Float     @default(0)
  paid           Float     @default(0)
  PaymentMethod  String?
  paymentStatus  String    @default("pending")
  paymentDate    DateTime?
  month          String
  year           Int
  isdeleted      Boolean   @default(false)
  deleteddate    DateTime?
  deleteby       String?
  module         String?   @default("payroll")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// 15. Fund Model (FinanceAndUtilities/Fund/fund.model.js)
model Fund {
  id          String    @id @default(uuid())
  tenantId    String
  branchName  String
  amount      Float
  type        String    // credit / debit
  description String
  date        DateTime  @default(now())
  isdeleted   Boolean   @default(false)
  deleteddate DateTime?
  deleteby    String?
  module      String?   @default("fund")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// 16. EBill Model (FinanceAndUtilities/ElectricityBill/ebill.model.js)
model EBill {
  id             String    @id @default(uuid())
  tenantId       String
  branchName     String
  month          String
  year           Int
  ebill          Float
  due            Float     @default(0)
  paid           Float     @default(0)
  PaymentMethod  String?
  paymentStatus  String    @default("pending")
  paymentDate    DateTime?
  isdeleted      Boolean   @default(false)
  deleteddate    DateTime?
  deleteby       String?
  module         String?   @default("ebill")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// 17. KitchenSummary Model (foodAndKitchen/kitchenSummary/summary.model.js)
model KitchenSummary {
  id                String   @id @default(uuid())
  tenantId          String
  branchName        String
  date              DateTime @default(now())
  presentStudents   Int      @default(0)
  absentStudents    Int      @default(0)
  morningVeg        Int      @default(0)
  morningNonVeg     Int      @default(0)
  afternoonVeg      Int      @default(0)
  afternoonNonVeg   Int      @default(0)
  nightVeg          Int      @default(0)
  nightNonVeg       Int      @default(0)
  specialBreakfast  Int      @default(0)
  specialLunch      Int      @default(0)
  specialDinner     Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// 18. KitchenHistory Model (foodAndKitchen/inventory/kitchenHistory.model.js)
model KitchenHistory {
  id         String   @id @default(uuid())
  tenantId   String
  branchName String
  itemId     String
  name       String
  category   String
  quantity   Float
  price      Float
  type       String   // add / remove
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 19. DueTracker Model (FinanceAndUtilities/dueTracker/dueTracker.model.js)
model DueTracker {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  amount     Float
  category   String
  dueDate    DateTime
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 20. KitchenExpenses Model (foodAndKitchen/expenses/expenses.model.js)
model KitchenExpenses {
  id         String   @id @default(uuid())
  tenantId   String
  branchName String
  name       String
  price      Float
  quantity   Float
  unit       String
  date       DateTime @default(now())
  category   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 21. KitchenInventory Model (foodAndKitchen/inventory/inventory.model.js)
model KitchenInventory {
  id                String   @id @default(uuid())
  tenantId          String
  branchName        String
  name              String
  category          String
  totalQuantity     Float    @default(0)
  remainingQuantity Float    @default(0)
  price             Float    @default(0)
  unit              String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// 22. Employee Model (employee/employee.model.js)
model Employee {
  id              String    @id @default(uuid())
  tenantId        String
  branchName      String
  staffName       String
  role            String
  shift           String?
  phoneNo         String
  email           String?
  password        String?
  salary          Float     @default(0)
  staying         Boolean   @default(true)
  vacatedate      DateTime?
  isdeleted       Boolean   @default(false)
  deleteddate     DateTime?
  deleteby        String?
  module          String?   @default("employee")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// 23. Advance Model (FinanceAndUtilities/advance/advance.model.js)
model Advance {
  id             String    @id @default(uuid())
  tenantId       String
  branchName     String
  employeeId     String
  name           String
  role           String
  salary         Float
  advance        Float
  paid           Float     @default(0)
  PaymentMethod  String?
  paymentStatus  String    @default("pending")
  paymentDate    DateTime?
  month          String
  year           Int
  isdeleted      Boolean   @default(false)
  deleteddate    DateTime?
  deleteby       String?
  module         String?   @default("advance")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// 24. DailyExpense Model (FinanceAndUtilities/dailyExpense/expense.model.js)
model DailyExpense {
  id          String    @id @default(uuid())
  tenantId    String
  branchName  String
  date        DateTime  @default(now())
  expenseName String
  category    String
  amount      Float
  description String?
  isdeleted   Boolean   @default(false)
  deleteddate DateTime?
  deleteby    String?
  module      String?   @default("dailyexpense")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// 25. Achievement Model (achievement/achievement.model.js)
model Achievement {
  id          String   @id @default(uuid())
  tenantId    String
  branchName  String
  title       String
  description String
  date        DateTime @default(now())
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 26. ResidentsAttendance Model (attendance/residentsAttendance/residentsAttendance.model.js)
model ResidentsAttendance {
  id          String   @id @default(uuid())
  tenantId    String
  branchName  String
  date        DateTime @default(now())
  presentList String[] @default([]) // Array of register IDs
  absentList  String[] @default([]) // Array of register IDs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 27. StaffAttendance Model (attendance/staffAttendance/staffAttendance.model.js)
model StaffAttendance {
  id          String   @id @default(uuid())
  tenantId    String
  branchName  String
  date        DateTime @default(now())
  presentList String[] @default([]) // Array of user/employee IDs
  absentList  String[] @default([]) // Array of user/employee IDs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
